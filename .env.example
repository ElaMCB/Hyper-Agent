# Copy to .env and fill in. Never commit .env.

# Optional: LLM for summarisation and drafting
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# Provider: openai | anthropic
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# Data paths (optional; defaults to ./data)
# DATA_DIR=./data

# Azure DevOps (morning brief: open Bugs)
# AZDO_PAT=your_pat_here
# AZDO_ORG=your-organization-name
# AZDO_PROJECT=YourProject
